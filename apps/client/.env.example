# URL base de la API. En dev se usa el proxy de Vite (definido abajo).
# En producción (Vercel) define esto con la URL del backend desplegado
# o usa el rewrite de vercel.json (ver apps/client/vercel.json).
VITE_API_URL=

# Prefijo de la API usado por el cliente (debe coincidir con setGlobalPrefix del backend).
VITE_API_PREFIX=/api

# Target del proxy de Vite en dev (donde corre el backend NestJS).
VITE_API_PROXY_TARGET=http://localhost:3000
